{
  "manifest_version": 3,
  "name": "Cappa Bridge",
  "version": "1.1",
  "description": "Tells the Cappa desktop app which YouTube video you're watching and where you are in it.",
  "permissions": ["cookies", "scripting"],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "*://*.youtube.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
